{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/music_video_script",
  "title": "Music Video Anime Script",
  "description": "Beat-anchored cut list for an AMV. Distinct from the general script schema: voice_performance is REQUIRED to be null (no narration), and every section carries a beat_anchor pointing to audiomap.",
  "type": "object",
  "required": ["version", "title", "total_duration_seconds", "voice_performance", "sections"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "title": { "type": "string" },
    "total_duration_seconds": { "type": "number", "minimum": 0.1 },
    "voice_performance": {
      "type": ["object", "null"],
      "description": "REQUIRED to be null on this pipeline. AMV has no narration. If non-null, schema validates shape but the composer will refuse to use voice_performance.",
      "properties": {
        "performance_intent": { "type": "string" },
        "pacing_profile": { "type": "string" },
        "energy_curve": { "type": "string" },
        "pause_policy": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "start_seconds", "end_seconds", "music_section_type", "beat_anchor"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "text": {
            "type": ["string", "null"],
            "const": null,
            "description": "REQUIRED null. No narration on this pipeline."
          },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "music_section_type": {
            "type": "string",
            "enum": ["intro", "verse", "pre_chorus", "chorus", "bridge", "outro"]
          },
          "motion_register_for_section": {
            "type": "string",
            "enum": ["kinetic-burst", "phrase-led", "hybrid-burst"]
          },
          "target_cut_count": { "type": "integer", "minimum": 1 },
          "beat_anchor": {
            "type": "object",
            "required": ["type", "t_seconds", "rationale"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["phrase_start", "downbeat", "phrase_end", "drop", "silence_start", "on_beat"]
              },
              "t_seconds": {
                "type": "number",
                "minimum": 0,
                "description": "Within ±50ms of audiomap.beats_sec / downbeats_sec / onsets_sec / key_moments.t"
              },
              "rationale": { "type": "string" }
            },
            "additionalProperties": false
          },
          "subtitle_cards": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["at_seconds", "text", "style"],
              "properties": {
                "at_beat_index": { "type": ["integer", "null"] },
                "at_seconds": { "type": "number" },
                "text": { "type": "string" },
                "style": {
                  "type": "string",
                  "enum": ["impact", "lyric-karaoke", "title"]
                }
              }
            }
          },
          "narrative_role": {
            "type": "string",
            "enum": ["establish_context", "build_tension", "deliver_payload", "emotional_beat", "transition", "call_to_action"]
          },
          "shot_intent": { "type": "string" },
          "source_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["motion_register_global", "audiomap_path"],
      "properties": {
        "motion_register_global": {
          "type": "string",
          "enum": ["kinetic-burst", "phrase-led", "hybrid-burst"]
        },
        "typography": {
          "type": "string",
          "enum": ["on-beat-karaoke", "sparse-on-impact", "none"]
        },
        "audiomap_path": { "type": "string" },
        "cut_density_per_minute": { "type": "integer", "minimum": 4 },
        "scene_count_total": { "type": "integer", "minimum": 1 },
        "language_of_subtitles": {
          "type": "string",
          "enum": ["zh", "en", "ja", "none"]
        }
      }
    }
  },
  "additionalProperties": false
}